variant: flatcar
version: 1.1.0
ignition:
  config:
    merge:
      - local: generated/base.ign
      - local: generated/base.k3s.ign
storage:
  links:
    - path: /etc/systemd/system/multi-user.target.wants/k3s-agent.service
      target: /usr/local/lib/systemd/system/k3s-agent.service
      overwrite: true
